<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许特定域名的明文 HTTP 流量 -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- 本地开发服务器 -->
        <domain includeSubdomains="true">192.168.15.199</domain>
        <domain includeSubdomains="true">192.168.15.200</domain>
        <domain includeSubdomains="true">192.168.18.182</domain>

        <!-- 其他需要 HTTP 的域名 -->
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>

    <!-- 允许所有明文流量（不推荐生产环境使用） -->
    <!--<base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>-->
</network-security-config>
